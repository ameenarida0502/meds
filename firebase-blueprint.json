{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system (Patient or Doctor)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "role": { "type": "string", "enum": ["patient", "doctor"] },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "bloodGroup": { "type": "string" },
        "address": { "type": "string" },
        "degree": { "type": "string" },
        "isSharingEnabled": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "role", "name", "email"]
    },
    "Record": {
      "title": "Medical Record",
      "description": "A medical record (prescription or report) uploaded by a patient",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "patientId": { "type": "string" },
        "fileURL": { "type": "string" },
        "fileName": { "type": "string" },
        "type": { "type": "string", "enum": ["prescription", "report"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "patientId", "fileURL", "type", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles for patients and doctors"
    },
    "/records/{recordId}": {
      "schema": "Record",
      "description": "Medical records repository"
    }
  }
}
